# Copy this file to .env and fill in your values.
# The app does NOT require these — users enter their API key in the browser.
# These are optional server-side defaults only.

# AI Provider — set to: anthropic | openai | ollama
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE
OPENAI_API_KEY=sk-YOUR-KEY-HERE

# Ollama settings (only used when AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
