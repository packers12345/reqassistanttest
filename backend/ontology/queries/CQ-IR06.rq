# CQ-IR06: Which requirements in a set have zero violations?
# Expected: List of requirement IDs with no violations in a given assessment
# Requires ABox instance data

PREFIX incose-req: <http://sie.arizona.edu/ontology/incose-req#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?reqId ?reqText
WHERE {
    ?req a incose-req:Requirement ;
         incose-req:hasRequirementId ?reqId ;
         incose-req:memberOfSet ?set .
    OPTIONAL { ?req incose-req:hasStatementText ?reqText . }

    ?assessment a incose-req:Assessment ;
                incose-req:assessesSet ?set ;
                incose-req:hasResult ?result .

    FILTER NOT EXISTS {
        ?result incose-req:includesViolation ?violation .
        ?violation incose-req:inheresInRequirement ?req .
    }
}
ORDER BY ?reqId
