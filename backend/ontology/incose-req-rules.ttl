incose-req:R35 a incose-req:Rule ;
    rdfs:label "Temporal Dependencies" ;
    incose-req:hasRuleId "R35" ;
    incose-req:hasShortDescription "Define temporal dependencies explicitly instead of using indefinite temporal keywords." ;
    incose-req:belongsToCategory incose-req:Cat-Quantification ;
    incose-req:hasApplicability incose-req:RNCR ;
    incose-req:requiresProjectDictionary false ;
    incose-req:testsCharacteristic
        incose-req:C3-Unambiguous ,
        incose-req:C4-Complete ,
        incose-req:C7-Verifiable .

