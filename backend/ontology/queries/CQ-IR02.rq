# CQ-IR02: What quality characteristics apply to requirement sets?
# Expected: List of 6 characteristics (C10-C15)

PREFIX incose-req: <http://sie.arizona.edu/ontology/incose-req#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?id ?label ?description
WHERE {
    ?char a incose-req:SetQualityCharacteristic ;
          incose-req:hasCharacteristicId ?id ;
          rdfs:label ?label .
    OPTIONAL { ?char incose-req:hasShortDescription ?description . }
}
ORDER BY ?id
